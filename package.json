{
  "name": "synesthizer",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean-audio": "for file in public/*.aiff; do ffmpeg -y -i $file -af silenceremove=start_periods=1:start_duration=0.1:start_threshold=-60dB ${file%%.aiff}.mp3; done",
    "dev": "next dev --turbopack",
    "export": "next build",
    "fmt": "biome format --write && biome check --write",
    "lint": "biome check && bun test",
    "start": "next start"
  },
  "dependencies": {
    "core-js": "^3.49.0",
    "lucide-react": "^1.17.0",
    "next": "16.2.7",
    "next-themes": "^0.4.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-dropzone": "^15.0.0",
    "tone": "^15.1.22",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/bun": "^1.3.14",
    "@types/node": "^24.13.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3"
  }
}
